generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql" // Ou "sqlite" se estiver usando arquivo local
  url      = env("DATABASE_URL")
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  name      String?
  role      String     @default("USER")
  createdAt DateTime   @default(now())
  movements Movement[] 
}

model Material {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  quantity    Float
  unit        String
  type        String
  location    String?  @default("Sem Localização")
  observation String?  @default("") // <--- CAMPO NOVO AQUI
  minStock    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movements Movement[]
}

model Movement {
  id         Int      @id @default(autoincrement())
  type       String
  quantity   Float
  reason     String?
  createdAt  DateTime @default(now())
  
  materialId Int
  material   Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  userId     Int?
  user       User?    @relation(fields: [userId], references: [id])
  
}