generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
 
}

datasource db {
  provider = "postgresql"
  schemas  = ["public", "sobra_corte", "autenticacao"]
}

model Material {
  id          Int      @id @default(autoincrement())
  code        String   @unique
  name        String
  quantity    Float    // Saldo Total na fábrica
  unit        String
  type        String
  observation String?  @default("")
  minStock    Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  movements   Movement[]
  locations   MaterialLocation[] // Relação com os múltiplos locais

  // 🚀 ÍNDICES DE ALTA PERFORMANCE (Evita Full Table Scan na busca)
  @@index([name])
  @@index([code])
  @@schema("sobra_corte")
}

// 📍 TABELA DE DOMÍNIO (Apenas locais pré-cadastrados, sem digitação livre)
model Location {
  id        Int      @id @default(autoincrement())
  name      String   @unique // Ex: "Prateleira A", "Corredor 2"
  
  materials MaterialLocation[]
  @@schema("sobra_corte")
}

// 🔗 TABELA DE JUNÇÃO (Material <-> Localização)
model MaterialLocation {
  materialId  Int
  locationId  Int

  // Se no futuro você quiser saber QUANTOS kg tem em CADA prateleira separadamente, 
  // nós já deixamos o campo de quantidade aqui pronto para uso!
  quantity    Float?   @default(0) 

  material    Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  location    Location @relation(fields: [locationId], references: [id], onDelete: Cascade)

  @@id([materialId, locationId]) // Impede que o mesmo material seja duplicado no mesmo local
  @@index([locationId]) // 🚀 ÍNDICE: Acelera a busca para saber "O que tem na prateleira X?"
  @@schema("sobra_corte")
}

model Movement {
  id           Int      @id @default(autoincrement())
  type         String
  quantity     Float
  reason       String?
  createdAt    DateTime @default(now())
  
  materialId   Int
  material     Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  // 👤 DADOS DA API DA DASS (Gravamos apenas o histórico, sem Foreign Key)
  operatorId   String?  // Matrícula vinda da DASS
  operatorName String?  // Nome vindo da DASS

  @@index([materialId])
  @@index([createdAt]) // 🚀 ÍNDICE: Faz o Top 5 e o Histórico carregarem em milissegundos
  @@schema("sobra_corte")
}

// 👤 TABELA DE USUÁRIOS (Persistência para Níveis de Acesso)
model User {
  id        Int      @id @default(autoincrement())
  usuario   String   @unique // Matrícula/Login da DASS (Ex: HELLEN.MAGALHAES)
  nome      String
  email     String   @unique
  setor     String?
  funcao    String?  // Cargo que vem do RH
  role      String   @default("leitor") // Nível de acesso manual do nosso sistema
 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

// Apenas a chave estrangeira para ligar com a DASS
  matriculaDass BigInt?  @unique
  dassInfo      UsuariosDass? @relation(fields: [matriculaDass], references: [matricula])

  // ÍNDICES DE ALTA PERFORMANCE (Evita Full Table Scan no momento do Login)
  @@index([usuario])
  @@index([email])
  @@schema("sobra_corte")
}

// Essa é a tabela de referencia de usuarios da api principal de autenticacao. Nao deve ser auterada de forma alguma, só deve ser utilizada como referencia ao usuario da api.
model UsuariosDass {
  id           BigInt    @default(autoincrement())
  createdAt    DateTime? @default(now()) @map("createdat") @db.Timestamptz
  updatedAt    DateTime? @default(now()) @map("updatedat") @db.Timestamptz
  codigoBarras BigInt    @map("codigo_barras")
  matricula    BigInt    @unique(map: "matricula_unique")
  nome         String?   @db.VarChar
  usuario      String?   @db.VarChar
  senha        String?   @db.VarChar
  funcao       String?   @db.VarChar
  setor        String?   @db.VarChar
  testeCalce   Int?      @default(0) @map("teste_calce")
  penseAja     Int?      @default(0) @map("pense_aja")
  season       Int?      @default(0)
  ambulatorio  Int?      @default(0)
  limpeza      Int?      @default(0)
  telas        Int?
  unidade      String?   @db.VarChar
  nivel        String?   @db.VarChar
  peConfirmado Int?      @map("pe_confirmado")
  rfid         BigInt?

  // Relação com a tabela User do app
  userApp      User?

  @@id([id, codigoBarras, matricula], map: "usuarios_pk")
  @@map("usuarios")
  @@schema("autenticacao")
}